{
	"name": "screenlite",
	"type": "module",
	"scripts": {
		"build": "rimraf dist && mkdir dist && npx swc src -d dist --strip-leading-paths && node scripts/fix-imports.js",
		"db:deploy": "npx prisma migrate deploy && npx prisma generate && npx prisma generate --sql",
		"db:reset": "npx prisma migrate reset && npx prisma generate",
		"dev": "[ -f .env ] && env-cmd -f .env tsx watch src/entrypoints/http.ts || tsx watch src/entrypoints/http.ts",
		"lint": "eslint --fix",
		"cli": "tsx src/entrypoints/cli.ts",
		"start": "node --env-file=.env dist/screenlite.js",
		"test": "vitest --bail=1",
		"env:sync": "node scripts/sync-env-docs.js"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.962.0",
		"@aws-sdk/s3-request-presigner": "^3.962.0",
		"@fastify/cors": "^11.2.0",
		"@fastify/deepmerge": "^3.1.0",
		"@fastify/formbody": "^8.0.2",
		"@fastify/helmet": "^13.0.2",
		"@fastify/multipart": "^9.3.0",
		"@fastify/sensible": "^6.0.4",
		"@prisma/adapter-pg": "^7.2.0",
		"@prisma/client": "^7.2.0",
		"@smithy/node-http-handler": "^4.4.7",
		"@smithy/types": "^4.11.0",
		"async-mutex": "^0.5.0",
		"axios": "^1.13.2",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.66.4",
		"cors": "^2.8.5",
		"fastify": "^5.6.2",
		"fastify-plugin": "^5.1.0",
		"fastify-type-provider-zod": "^6.1.0",
		"glob": "^13.0.0",
		"i18next": "^25.7.3",
		"i18next-fs-backend": "^2.6.1",
		"i18next-http-middleware": "^3.9.2",
		"ioredis": "^5.8.2",
		"mime": "^4.1.0",
		"multer": "^2.0.2",
		"nodemailer": "^7.0.12",
		"pg": "^8.16.3",
		"sharp": "^0.34.5",
		"swagger-jsdoc": "^6.2.8",
		"uuid": "^13.0.0",
		"ws": "^8.18.3",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@stylistic/eslint-plugin": "^5.6.1",
		"@swc/cli": "^0.7.9",
		"@swc/core": "^1.15.8",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/multer": "^2.0.0",
		"@types/node": "^25.0.3",
		"@types/nodemailer": "^7.0.4",
		"@types/pg": "^8.16.0",
		"@types/supertest": "^6.0.3",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/tmp": "^0.2.6",
		"@types/uuid": "^11.0.0",
		"@types/ws": "^8.18.1",
		"env-cmd": "^11.0.0",
		"eslint": "^9.39.2",
		"globals": "^17.0.0",
		"prisma": "^7.2.0",
		"rimraf": "^6.1.2",
		"supertest": "^7.1.4",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.51.0",
		"vitest": "^4.0.16"
	}
}
